    <param name="fixed_frame" value=""/>
    <param name="target_frame" value=""/>
    <param name="organize_cloud" value="false"/>
  </node>-->
  <!-- mid360 -->
  <include file="$(find-pkg-share livox_ros_driver2)/launch_ROS2/msg_MID360_launch.py">
  </include>
